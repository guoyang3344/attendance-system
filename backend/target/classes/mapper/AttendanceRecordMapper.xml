<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.attendance.mapper.AttendanceRecordMapper">

    <resultMap id="AttendanceRecordResultMap" type="com.example.attendance.entity.AttendanceRecord">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="punch_in_time" property="punchInTime"/>
        <result column="punch_out_time" property="punchOutTime"/>
        <result column="punch_date" property="punchDate"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
        <result column="real_name" property="realName"/>
    </resultMap>

    <select id="selectTodayRecordByUserId" resultMap="AttendanceRecordResultMap">
        SELECT * FROM attendance_record 
        WHERE user_id = #{userId} AND punch_date = #{today} AND deleted = 0
        LIMIT 1
    </select>

    <select id="selectByUserId" resultMap="AttendanceRecordResultMap">
        SELECT * FROM attendance_record 
        WHERE user_id = #{userId} AND deleted = 0
        ORDER BY punch_date DESC
    </select>

    <select id="selectAllRecordsWithUser" resultMap="AttendanceRecordResultMap">
        SELECT ar.*, u.real_name
        FROM attendance_record ar
        LEFT JOIN sys_user u ON ar.user_id = u.id
        WHERE ar.deleted = 0
        ORDER BY ar.punch_date DESC, ar.user_id
    </select>
</mapper>
